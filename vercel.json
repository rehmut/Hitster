{
    "version": 2,
    "builds": [
        {
            "src": "api/leaderboard.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/predictions.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/room/create.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/room/join.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/room/leave.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/room/player.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/room/status.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/room/update.py",
            "use": "@vercel/python"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1.py"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ]
}
