{
    "version": 2,
    "builds": [
        {
            "src": "api/leaderboard.py",
            "use": "@vercel/python"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/leaderboard",
            "dest": "/api/leaderboard.py"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ]
}
